###
POST {{host}}/api/auth/login
Content-Type: application/json

{"username": "ahmed.l1", "password": "MotDePasse123"}

### M2-6.3 — Trouver une alerte NEW
GET {{host}}/api/alerts?status=NEW&size=1

> {%
    client.test("M2-6.3 Alerte NEW pour incident 3", function() {
        client.assert(response.status === 200);
        client.assert(response.body.content.length > 0);
        client.global.set("escAlertId3", response.body.content[0].id);
    });
%}

### M2-6.4 — Créer incident 3 assigné à L2
POST {{host}}/api/incidents
Content-Type: application/json

{
  "title": "FIM-VITAL-01 — Modification /etc/shadow",
  "severity": "CRITICAL",
  "triageNote": "Hash de /etc/shadow modifié. Compromission probable.",
  "assignedToUserId": {{l2UserId}},
  "alertIds": [{{escAlertId3}}]
}

> {%
    client.test("M2-6.4 Incident 3 créé", function() {
        client.assert(response.status === 201);
        client.global.set("incidentId3", response.body.id);
    });
%}

### M2-6.5 — Login Manager
POST {{host}}/api/auth/logout

###
POST {{host}}/api/auth/login
Content-Type: application/json

{"username": "karim.mgr", "password": "MotDePasse789"}

### M2-6.6 — Manager réassigne l'incident 3
PUT {{host}}/api/incidents/{{incidentId3}}/reassign
Content-Type: application/json

{
  "newAssigneeUserId": {{l2UserId}},
  "note": "Sara a plus d'expérience sur les incidents d'intégrité de fichiers."
}

> {%
    client.test("M2-6.6 Réassignation OK", function() {
        client.assert(response.status === 200);
    });
%}

### M2-6.7 — Vérifier la timeline de réassignation
GET {{host}}/api/incidents/{{incidentId3}}

> {%
    client.test("M2-6.7 Timeline contient la réassignation", function() {
        client.assert(response.status === 200);
        var hasReassign = response.body.timeline.some(e => e.entryType === "REASSIGNMENT");
        client.assert(hasReassign, "La timeline doit contenir une entrée REASSIGNMENT");
    });
%}

### M2-6.8 — Déconnexion finale
POST {{host}}/api/auth/logout

> {%
    client.test("Déconnexion finale OK", function() {
        client.assert(response.status === 200);
    });
%}


### ============================================================
### FIN DES TESTS MODULE 2
### ============================================================
### Résumé :
###   ✓ Création d'incident via POST /api/incidents (L1)
###   ✓ Escalade raccourci via PUT /api/alerts/{id}/escalate (L1)
###   ✓ Double escalade interdite (409)
###   ✓ Note de triage obligatoire (400)
###   ✓ Prise en charge L2 + protection concurrence
###   ✓ Cycle complet : OPEN → INVESTIGATING → REMEDIATING → RESOLVED → CLOSED
###   ✓ Retour arrière : REMEDIATING → INVESTIGATING
###   ✓ Transition interdite (400)
###   ✓ Renvoi au L1 (faux positif → CLOSED_FALSE_POSITIVE)
###   ✓ Réassignation par Manager
###   ✓ Timeline vérifiée à chaque étape
### ============================================================
