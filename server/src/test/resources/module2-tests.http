  "justification": "Après investigation, il s'agit du scanner Nessus interne (IP 192.168.1.50). Pas une vraie attaque."
}

> {%
    client.test("M2-5.2 Renvoi au L1 OK", function() {
        client.assert(response.status === 200);
    });
%}

### M2-5.3 — Vérifier que l'incident est CLOSED_FALSE_POSITIVE
GET {{host}}/api/incidents/{{incidentId2}}

> {%
    client.test("M2-5.3 Incident CLOSED_FALSE_POSITIVE", function() {
        client.assert(response.status === 200);
        client.assert(response.body.incident.status === "CLOSED_FALSE_POSITIVE");
    });
%}

### M2-5.4 — Déconnexion L2
POST {{host}}/api/auth/logout


