### Variables globales (IntelliJ gère automatiquement les cookies !)
@host = http://localhost:8080
@adminUser = admin
@adminPass = admin
@newUser = ahmed.11
@newPass = MotDePasse123

### ===================================================================
### SCÉNARIO 1 : TESTS DU COMPTE ADMIN (INITIALISÉ AU DÉMARRAGE)
### ===================================================================

### 1.1 - Login avec le compte Admin par défaut
# Devrait renvoyer 200 OK avec les infos de l'admin
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUser}}",
  "password": "{{adminPass}}"
}

> {%
    client.test("Login Admin réussi", function() {
        client.assert(response.status === 200, "Le statut devrait être 200");
        client.assert(response.body.role === "ADMIN", "Le rôle devrait être ADMIN");
        client.global.set("authCookie", response.headers.valueOf("Set-Cookie"));
    });
%}

### 1.2 - Vérification de la session (me)
# Devrait renvoyer 200 OK car on vient de se connecter
GET {{host}}/api/auth/me

> {%
    client.test("Session active", function() {
        client.assert(response.status === 200, "Le statut devrait être 200");
    });
%}

### ===================================================================
### SCÉNARIO 2 : GESTION DES UTILISATEURS (EN TANT QU'ADMIN)
### ===================================================================

### 2.1 - Créer un nouvel analyste L1
# Devrait renvoyer 201 Created
POST {{host}}/api/admin/users
Content-Type: application/json

{
  "username": "{{newUser}}",
  "password": "{{newPass}}",
  "fullName": "Ahmed Benali",
  "role": "L1",
  "email": "ahmed@warroom.local"
}

> {%
    client.test("Création réussie", function() {
        client.assert(response.status === 201, "Le statut devrait être 201");
        // On sauvegarde l'ID du nouvel utilisateur pour plus tard
        client.global.set("newUserId", response.body.userId);
    });
%}

### 2.2 - Tenter de créer un utilisateur avec un pseudo existant
# Devrait renvoyer 409 Conflict
POST {{host}}/api/admin/users
Content-Type: application/json

{
  "username": "{{newUser}}",
  "password": "unAutrePassword",
  "fullName": "Un Autre Ahmed",
  "role": "L2"
}

> {%
    client.test("Conflit détecté", function() {
        client.assert(response.status === 409, "Le statut devrait être 409 Conflict");
    });
%}

### 2.3 - Lister tous les utilisateurs
# Devrait renvoyer un tableau JSON (l'admin + le nouveau L1)
GET {{host}}/api/admin/users

> {%
    client.test("Liste récupérée", function() {
        client.assert(response.status === 200, "Le statut devrait être 200");
        client.assert(response.body.length >= 2, "Il devrait y avoir au moins 2 utilisateurs");
    });
%}

