### 3.4 - Test Anti-Bruteforce (Échec 6 - Le blocage !)
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "{{newUser}}",
  "password": "mauvaisPassword"
}

> {%
    client.test("Compte verrouillé après 5 échecs", function() {
        client.assert(response.status === 423, "Le statut devrait être 423 Locked");
    });
%}

### 3.5 - Test de connexion valide mais sur compte verrouillé
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "{{newUser}}",
  "password": "{{newPass}}"
}

> {%
    client.test("Toujours verrouillé même avec le bon mot de passe", function() {
        client.assert(response.status === 423, "Le statut devrait être 423 Locked");
    });
%}

