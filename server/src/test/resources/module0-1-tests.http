### M1-1.1 — Liste par défaut (page 0, 20 éléments)
GET {{host}}/api/alerts?page=0&size=20

> {%
    client.test("M1-1.1 Liste alertes OK", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.content.length > 0, "Au moins 1 alerte");
        client.assert(response.body.totalElements >= 15, "Au moins 15 alertes mock");
    });
%}

### M1-1.2 — Pagination : page 0, taille 5
GET {{host}}/api/alerts?page=0&size=5

> {%
    client.test("M1-1.2 Pagination 5/page", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.content.length <= 5, "Max 5 éléments");
        client.assert(response.body.totalPages >= 3, "Au moins 3 pages");
    });
%}

### M1-1.3 — Page 2
GET {{host}}/api/alerts?page=1&size=5

> {%
    client.test("M1-1.3 Page 2 OK", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.number === 1, "Page index = 1");
    });
%}


### ============================================================
### MODULE 1 — SCÉNARIO 2 : FILTRES DYNAMIQUES
### ============================================================

### M1-2.1 — Filtre par sévérité CRITICAL
GET {{host}}/api/alerts?severity=CRITICAL

> {%
    client.test("M1-2.1 Filtre CRITICAL", function() {
        client.assert(response.status === 200, "Status 200");
        var allCritical = response.body.content.every(a => a.severity === "CRITICAL");
        client.assert(allCritical, "Toutes les alertes sont CRITICAL");
        client.assert(response.body.content.length >= 4, "Au moins 4 CRITICAL");
        // Sauvegarder une alerte CRITICAL pour les tests suivants
        client.global.set("criticalAlertId", response.body.content[0].id);
    });
%}

### M1-2.2 — Filtre multi-sévérité : CRITICAL + HIGH
GET {{host}}/api/alerts?severity=CRITICAL,HIGH

> {%
    client.test("M1-2.2 Filtre CRITICAL+HIGH", function() {
        client.assert(response.status === 200, "Status 200");
        var valid = response.body.content.every(a => a.severity === "CRITICAL" || a.severity === "HIGH");
        client.assert(valid, "Toutes sont CRITICAL ou HIGH");
    });
%}

### M1-2.3 — Filtre par statut NEW
GET {{host}}/api/alerts?status=NEW

> {%
    client.test("M1-2.3 Filtre NEW", function() {
        client.assert(response.status === 200, "Status 200");
        var allNew = response.body.content.every(a => a.status === "NEW");
        client.assert(allNew, "Toutes les alertes sont NEW");
    });
%}

### M1-2.4 — Filtre par agent
GET {{host}}/api/alerts?agentId=agt-mock-001

> {%
    client.test("M1-2.4 Filtre agent-001", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.content.length > 0, "Au moins 1 alerte");
    });
%}

### M1-2.5 — Filtres combinés : CRITICAL + NEW + agent-001
GET {{host}}/api/alerts?severity=CRITICAL&status=NEW&agentId=agt-mock-001

> {%
    client.test("M1-2.5 Filtres combinés", function() {
        client.assert(response.status === 200, "Status 200");
        var valid = response.body.content.every(a =>
            a.severity === "CRITICAL" && a.status === "NEW"
        );
        client.assert(valid, "Toutes CRITICAL + NEW");
    });
%}

### M1-2.6 — Filtre sans résultat (agent inexistant)
GET {{host}}/api/alerts?agentId=agt-fake-999

> {%
    client.test("M1-2.6 Aucun résultat", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.content.length === 0, "Liste vide");
        client.assert(response.body.totalElements === 0, "Total = 0");
    });
%}


### ============================================================
### MODULE 1 — SCÉNARIO 3 : DÉTAIL D'UNE ALERTE
### ============================================================

### M1-3.1 — Détail de l'alerte CRITICAL
GET {{host}}/api/alerts/{{criticalAlertId}}

> {%
    client.test("M1-3.1 Détail alerte OK", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.alert !== undefined, "Champ alert présent");
        client.assert(response.body.agent !== undefined, "Champ agent présent");
        client.assert(response.body.recentAlerts !== undefined, "Champ recentAlerts présent");
        client.assert(response.body.recentAlerts.length <= 10, "Max 10 alertes contextuelles");
    });
%}

### M1-3.2 — Détail avec sourceEvent
GET {{host}}/api/alerts/{{criticalAlertId}}

> {%
    client.test("M1-3.2 SourceEvent présent", function() {
        client.assert(response.status === 200, "Status 200");
        // Le sourceEvent devrait contenir le payload brut
        if (response.body.sourceEvent && response.body.sourceEvent.payload) {
            client.assert(response.body.sourceEvent.payload.length > 0, "Payload non vide");
        }
    });
%}

### M1-3.3 — Détail d'une alerte inexistante → 404
GET {{host}}/api/alerts/99999

> {%
    client.test("M1-3.3 Alerte introuvable 404", function() {
        client.assert(response.status === 404, "Status 404");
    });
%}


### ============================================================
### MODULE 1 — SCÉNARIO 4 : ACQUITTEMENT (Workflow L1)
### ============================================================

### M1-4.1 — Acquitter une alerte CRITICAL
PUT {{host}}/api/alerts/{{criticalAlertId}}/acknowledge

> {%
    client.test("M1-4.1 Acquittement OK", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.status === "ACKNOWLEDGED", "Status ACKNOWLEDGED");
        client.assert(response.body.qualifiedAt !== null, "qualifiedAt rempli");
    });
%}

### M1-4.2 — Double acquittement → 409
PUT {{host}}/api/alerts/{{criticalAlertId}}/acknowledge

> {%
    client.test("M1-4.2 Double acquittement interdit", function() {
        client.assert(response.status === 409, "Status 409 Conflict");
    });
%}

### M1-4.3 — Vérifier que le filtre NEW exclut l'alerte acquittée
GET {{host}}/api/alerts?status=NEW

> {%
    client.test("M1-4.3 Alerte acquittée exclue du filtre NEW", function() {
        client.assert(response.status === 200, "Status 200");
        var found = response.body.content.some(a => a.id == client.global.get("criticalAlertId"));
        client.assert(!found, "L'alerte acquittée ne doit plus apparaître dans les NEW");
    });
%}

### M1-4.4 — Filtre ACKNOWLEDGED montre l'alerte
GET {{host}}/api/alerts?status=ACKNOWLEDGED

> {%
    client.test("M1-4.4 Alerte visible dans ACKNOWLEDGED", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.content.length >= 1, "Au moins 1 ACKNOWLEDGED");
    });
%}


