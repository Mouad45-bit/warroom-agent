### ============================================================
### WARROOM SOC — TESTS COMPLETS MODULES 0 & 1
### ============================================================
### Exécuter dans l'ordre. IntelliJ gère les cookies automatiquement.
###
### PRÉREQUIS :
### 1. Le serveur tourne sur localhost:8080
### 2. La base a été créée (ddl-auto=create au premier démarrage)
### 3. Le script mock-data.sql a été exécuté dans pgAdmin
### ============================================================

@host = http://localhost:8080


### ============================================================
### MODULE 0 — SCÉNARIO 1 : ADMIN PAR DÉFAUT
### ============================================================

### M0-1.1 — Login Admin par défaut
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin"
}

> {%
    client.test("M0-1.1 Login Admin OK", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.role === "ADMIN", "Rôle ADMIN");
        client.assert(response.body.username === "admin", "Username admin");
    });
%}

### M0-1.2 — Vérification session /me
GET {{host}}/api/auth/me

> {%
    client.test("M0-1.2 Session active", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.role === "ADMIN", "Rôle ADMIN");
    });
%}


### ============================================================
### MODULE 0 — SCÉNARIO 2 : CRÉATION DE COMPTES
### ============================================================

### M0-2.1 — Créer un analyste L1
POST {{host}}/api/admin/users
Content-Type: application/json

{
  "username": "ahmed.l1",
  "password": "MotDePasse123",
  "fullName": "Ahmed Benali",
  "role": "L1",
  "email": "ahmed@warroom.local"
}

> {%
    client.test("M0-2.1 L1 créé", function() {
        client.assert(response.status === 201, "Status 201");
        client.assert(response.body.role === "L1", "Rôle L1");
        client.global.set("l1UserId", response.body.userId);
    });
%}

### M0-2.2 — Créer un analyste L2
POST {{host}}/api/admin/users
Content-Type: application/json

{
  "username": "sara.l2",
  "password": "MotDePasse456",
  "fullName": "Sara El Amrani",
  "role": "L2",
  "email": "sara@warroom.local"
}

> {%
    client.test("M0-2.2 L2 créé", function() {
        client.assert(response.status === 201, "Status 201");
        client.assert(response.body.role === "L2", "Rôle L2");
        client.global.set("l2UserId", response.body.userId);
    });
%}

### M0-2.3 — Créer un Manager
POST {{host}}/api/admin/users
Content-Type: application/json

{
  "username": "karim.mgr",
  "password": "MotDePasse789",
  "fullName": "Karim Idrissi",
  "role": "MANAGER",
  "email": "karim@warroom.local"
}

> {%
    client.test("M0-2.3 Manager créé", function() {
        client.assert(response.status === 201, "Status 201");
        client.assert(response.body.role === "MANAGER", "Rôle MANAGER");
    });
%}

### M0-2.4 — Conflit : pseudo déjà pris
POST {{host}}/api/admin/users
Content-Type: application/json

{
  "username": "ahmed.l1",
  "password": "autre",
  "fullName": "Autre Ahmed",
  "role": "L2"
}

> {%
    client.test("M0-2.4 Conflit 409", function() {
        client.assert(response.status === 409, "Status 409");
    });
%}

### M0-2.5 — Rôle invalide
POST {{host}}/api/admin/users
Content-Type: application/json

{
  "username": "test.invalid",
  "password": "test",
  "fullName": "Test",
  "role": "SUPERADMIN"
}

> {%
    client.test("M0-2.5 Rôle invalide 400", function() {
        client.assert(response.status === 400, "Status 400");
    });
%}

### M0-2.6 — Lister tous les utilisateurs
GET {{host}}/api/admin/users

> {%
    client.test("M0-2.6 Liste users", function() {
        client.assert(response.status === 200, "Status 200");
        client.assert(response.body.length >= 4, "Au moins 4 utilisateurs (admin + 3 créés)");
    });
%}


