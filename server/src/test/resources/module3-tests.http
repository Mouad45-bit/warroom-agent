### ============================================================
### SCÉNARIO 6 : VÉRIFICATION TIMELINE COMPLÈTE
### ============================================================

### M3-6.1 — Login L2
POST {{host}}/api/auth/login
Content-Type: application/json

{"username": "sara.l2", "password": "MotDePasse456"}

### M3-6.2 — Vérifier la timeline de l'incident (tout doit y être)
GET {{host}}/api/incidents/{{m3IncidentId}}

> {%
    client.test("M3-6.2 Timeline complète", function() {
        client.assert(response.status === 200);

        var timeline = response.body.timeline;
        client.assert(timeline.length >= 9, "Au moins 9 entrées timeline");

        // Vérifier la présence des types
        var types = timeline.map(e => e.entryType);
        client.assert(types.includes("STATUS_CHANGE"), "STATUS_CHANGE présent");
        client.assert(types.includes("COUNTERMEASURE"), "COUNTERMEASURE présent");
        client.assert(types.includes("NOTE"), "NOTE présent");

        // Compter les contre-mesures
        var countermeasures = timeline.filter(e => e.entryType === "COUNTERMEASURE");
        client.assert(countermeasures.length >= 5, "Au moins 5 contre-mesures");

        // Vérifier que countermeasureType est rempli
        var blockIp = countermeasures.find(c => c.countermeasureType === "BLOCK_IP");
        client.assert(blockIp !== undefined, "BLOCK_IP trouvé");

        // Vérifier que technicalCommand est rempli sur au moins une
        var withCommand = countermeasures.find(c => c.technicalCommand !== null && c.technicalCommand.length > 0);
        client.assert(withCommand !== undefined, "Au moins 1 avec commande technique");

        // Compter les notes
        var notes = timeline.filter(e => e.entryType === "NOTE");
        client.assert(notes.length >= 3, "Au moins 3 notes (L2 + L1 + Manager)");

        // Vérifier les rôles des auteurs de notes
        var noteRoles = notes.map(n => n.authorRole);
        client.assert(noteRoles.includes("L2"), "Note L2 présente");
        client.assert(noteRoles.includes("L1"), "Note L1 présente");
        client.assert(noteRoles.includes("MANAGER"), "Note Manager présente");
    });
%}

### M3-6.3 — Déconnexion finale
POST {{host}}/api/auth/logout

> {%
    client.test("Déconnexion OK", function() {
        client.assert(response.status === 200);
    });
%}


