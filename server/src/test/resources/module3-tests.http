### ============================================================
### WARROOM SOC — TESTS MODULE 3 : CONTRE-MESURES & NOTES
### ============================================================
### Prérequis :
### 1. Modules 0, 1, 2 exécutés (users + alertes + incidents)
### 2. Au moins un incident avec un L2 assigné
### ============================================================

@host = http://localhost:8080
### Variables globales




### ============================================================
### PRÉREQUIS : CRÉER UN INCIDENT EN STATUT REMEDIATING
### ============================================================

### M3-0.1 — Login L1
POST {{host}}/api/auth/login
Content-Type: application/json

{"username": "ahmed.l1", "password": "MotDePasse123"}

### M3-0.2 — Trouver une alerte NEW
GET {{host}}/api/alerts?status=NEW&size=1

> {%
    client.test("Alerte trouvée", function() {
        client.assert(response.status === 200);
        client.assert(response.body.content.length > 0);
        client.global.set("m3AlertId", response.body.content[0].id);
    });
%}

### M3-0.3 — Créer un incident assigné au L2
POST {{host}}/api/incidents
Content-Type: application/json

{
  "title": "MODULE3-TEST — Incident pour tester les contre-mesures",
  "severity": "HIGH",
  "triageNote": "Incident créé pour les tests Module 3.",
  "assignedToUserId": {{l2UserId}},
  "alertIds": [{{m3AlertId}}]
}

> {%
    client.test("Incident Module 3 créé", function() {
        client.assert(response.status === 201);
        client.global.set("m3IncidentId", response.body.id);
    });
%}

### M3-0.4 — Logout L1
POST {{host}}/api/auth/logout

### M3-0.5 — Login L2
POST {{host}}/api/auth/login
Content-Type: application/json

{"username": "sara.l2", "password": "MotDePasse456"}

### M3-0.6 — L2 fait avancer l'incident → INVESTIGATING
PUT {{host}}/api/incidents/{{m3IncidentId}}/status
Content-Type: application/json

{
  "newStatus": "INVESTIGATING",
  "note": "Début de l'investigation pour les tests Module 3."
}

> {%
    client.test("→ INVESTIGATING", function() {
        client.assert(response.status === 200);
    });
%}


### ============================================================
### SCÉNARIO 1 : CONTRE-MESURES SUR UN INCIDENT NON-REMEDIATING
### ============================================================

### M3-1.1 — Contre-mesure sur INVESTIGATING → 201 + warning
POST {{host}}/api/incidents/{{m3IncidentId}}/countermeasures
Content-Type: application/json

{
  "type": "BLOCK_IP",
  "description": "Blocage urgent de l'IP source avant passage en remédiation",
  "technicalCommand": "iptables -A INPUT -s 192.168.1.50 -j DROP"
}

> {%
    client.test("M3-1.1 Contre-mesure OK + warning", function() {
        client.assert(response.status === 201);
        client.assert(response.body.warning !== null, "Warning attendu car pas en REMEDIATING");
        client.assert(response.body.id > 0, "ID de l'entrée timeline retourné");
    });
%}


### ============================================================
### SCÉNARIO 2 : PASSAGE EN REMEDIATING + CONTRE-MESURES NORMALES
### ============================================================

### M3-2.1 — Passer en REMEDIATING
PUT {{host}}/api/incidents/{{m3IncidentId}}/status
Content-Type: application/json

{
  "newStatus": "REMEDIATING",
  "note": "IP identifiée. Passage en remédiation."
}

> {%
    client.test("→ REMEDIATING", function() {
        client.assert(response.status === 200);
    });
%}

### M3-2.2 — Contre-mesure BLOCK_IP (sans warning)
POST {{host}}/api/incidents/{{m3IncidentId}}/countermeasures
Content-Type: application/json

{
  "type": "BLOCK_IP",
  "description": "Blocage définitif de l'IP source 192.168.1.50",
  "technicalCommand": "iptables -A INPUT -s 192.168.1.50 -j DROP && iptables-save > /etc/iptables/rules.v4"
}

> {%
    client.test("M3-2.2 BLOCK_IP OK sans warning", function() {
        client.assert(response.status === 201);
        client.assert(response.body.warning === null, "Pas de warning en REMEDIATING");
    });
%}

