### ============================================================
### ÉTAPE 5 : ACQUITTER UNE ALERTE → audit ALERT_ACKNOWLEDGED
### ============================================================

### M6-5.1 — Trouver une alerte NEW
GET {{host}}/api/alerts?status=NEW&size=3

> {%
    client.test("M6-5.1 Alertes trouvées", function() {
        client.assert(response.status === 200);
        client.assert(response.body.content.length > 0);
        client.global.set("auditAlertId1", response.body.content[0].id);
        if (response.body.content.length > 1) {
            client.global.set("auditAlertId2", response.body.content[1].id);
        }
        if (response.body.content.length > 2) {
            client.global.set("auditAlertId3", response.body.content[2].id);
        }
    });
%}

### M6-5.2 — Acquitter
PUT {{host}}/api/alerts/{{auditAlertId1}}/acknowledge

> {%
    client.test("M6-5 ALERT_ACKNOWLEDGED", function() {
        client.assert(response.status === 200);
    });
%}


