  "triageNote": "Test du module 6 — vérification de l'audit trail.",
  "assignedToUserId": null,
  "additionalAlertIds": []
}

> {%
    client.test("M6-7 INCIDENT_CREATED + ALERT_ESCALATED", function() {
        client.assert(response.status === 201);
        client.global.set("auditIncidentId", response.body.id);
    });
%}

