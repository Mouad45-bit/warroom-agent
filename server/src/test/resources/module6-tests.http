### ============================================================
### ÉTAPE 15 : CONSULTER LE JOURNAL D'AUDIT
### ============================================================

### M6-15.1 — Journal complet (page 0, 30 éléments)
GET {{host}}/api/admin/audit-log?page=0&size=30

> {%
    client.test("M6-15.1 Journal d'audit accessible", function() {
        client.assert(response.status === 200);
        client.assert(response.body.totalElements >= 10, "Au moins 10 entrées d'audit");

        var actions = response.body.content.map(e => e.actionType);
        client.assert(actions.includes("LOGIN"), "LOGIN présent");
        client.assert(actions.includes("LOGOUT"), "LOGOUT présent");
        client.assert(actions.includes("USER_CREATED"), "USER_CREATED présent");
        client.assert(actions.includes("ALERT_ACKNOWLEDGED"), "ALERT_ACKNOWLEDGED présent");
        client.assert(actions.includes("ALERT_FALSE_POSITIVE"), "ALERT_FALSE_POSITIVE présent");
        client.assert(actions.includes("ALERT_ESCALATED"), "ALERT_ESCALATED présent");
        client.assert(actions.includes("INCIDENT_CREATED"), "INCIDENT_CREATED présent");
        client.assert(actions.includes("INCIDENT_TAKEN"), "INCIDENT_TAKEN présent");
        client.assert(actions.includes("INCIDENT_STATUS_CHANGED"), "INCIDENT_STATUS_CHANGED présent");
        client.assert(actions.includes("INCIDENT_COUNTERMEASURE_ADDED"), "COUNTERMEASURE présent");
        client.assert(actions.includes("INCIDENT_NOTE_ADDED"), "NOTE présent");
        client.assert(actions.includes("INCIDENT_CLOSED"), "INCIDENT_CLOSED présent");
    });
%}

### M6-15.2 — Filtrer par userId
GET {{host}}/api/admin/audit-log?userId={{auditL1Id}}

> {%
    client.test("M6-15.2 Filtre par userId", function() {
        client.assert(response.status === 200);
    });
%}

### M6-15.3 — Filtrer par actionType
GET {{host}}/api/admin/audit-log?actionType=LOGIN,LOGOUT

> {%
    client.test("M6-15.3 Filtre par actionType", function() {
        client.assert(response.status === 200);
        var valid = response.body.content.every(e => e.actionType === "LOGIN" || e.actionType === "LOGOUT");
        client.assert(valid, "Toutes les entrées sont LOGIN ou LOGOUT");
    });
%}

### M6-15.4 — Filtrer par targetType
GET {{host}}/api/admin/audit-log?targetType=INCIDENT

> {%
    client.test("M6-15.4 Filtre par targetType", function() {
        client.assert(response.status === 200);
        var valid = response.body.content.every(e => e.targetType === "INCIDENT");
        client.assert(valid, "Toutes les entrées ciblent un INCIDENT");
    });
%}

### M6-15.5 — Logout Manager
POST {{host}}/api/auth/logout


