POST {{host}}/api/auth/logout

### M6-16.7 — Login_Failed pour vérifier l'audit
POST {{host}}/api/auth/login
Content-Type: application/json

{"username": "ahmed.l1", "password": "mauvais_mdp"}

> {%
    client.test("M6-16.7 LOGIN_FAILED généré", function() {
